# ============================================================
# Jarvis AI Assistant — .env.example
# ============================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to Git!
#
#   cp .env.example .env
#
# ============================================================

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ---------------------------------------------------------------------------
# AI Provider Selection
# ---------------------------------------------------------------------------
# Options: "gemini" | "groq" | "openai" | "auto"
# "auto" = tries gemini → groq → openai in order, uses first that works
AI_PROVIDER=gemini

# ---------------------------------------------------------------------------
# Google Gemini API (FREE — 1500 requests/day)
# Get key: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# Groq API (FREE — fast LLaMA 3.3 70B)
# Get key: https://console.groq.com/keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here

# ---------------------------------------------------------------------------
# OpenAI API (PAID — GPT-4o-mini)
# Get key: https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
