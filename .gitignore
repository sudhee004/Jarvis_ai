# ============================================================
# Jarvis AI Assistant — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
.venv/
ENV/

# Environment variables (NEVER commit API keys)
.env
*.env

# Database
db.sqlite3
db.sqlite3-journal

# Media uploads (user files)
media/

# Collected static files (generated by collectstatic)
staticfiles/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Byte-compiled / cached
*.egg-info/
dist/
build/
*.egg

# Logs
*.log

# Coverage / testing
htmlcov/
.coverage
.pytest_cache/
